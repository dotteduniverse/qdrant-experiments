# Qdrant Connection Settings
# For local Docker
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=http://localhost:6333

# For Qdrant Cloud (uncomment and fill in)
# QDRANT_URL=https://your-cluster.cloud.qdrant.io
# QDRANT_API_KEY=your-secret-api-key

# Default collection name used by experiments
DEFAULT_COLLECTION=experiment_collection

# Embedding model (optional, defaults to all-MiniLM-L6-v2)
EMBEDDING_MODEL=all-MiniLM-L6-v2